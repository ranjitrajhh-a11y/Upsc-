</div>

<h2 id="question" class="mb-4"></h2>
<div id="options" class="grid grid-cols-2 gap-4"></div>

<div id="explanation" class="hidden mt-4 p-3 bg-gray-700 rounded"></div>

<div class="flex justify-between mt-6">
<button onclick="goBack()" class="bg-gray-600 px-4 py-2 rounded">Back</button>
<button onclick="openExitPopup()" class="bg-red-500 px-4 py-2 rounded">Exit</button>
<button onclick="nextQuestion()" class="bg-blue-500 px-4 py-2 rounded">Next</button>
</div>
</div>

<div id="resultBox" class="hidden text-center">
