<p>Wrong: <span id="wrong"></span></p>

<button onclick="retakeWrong()" class="mt-4 bg-red-500 px-4 py-2 rounded">Retake Wrong</button>
<button onclick="restartQuiz()" class="mt-4 bg-blue-500 px-4 py-2 rounded">Restart</button>
</div>

</div>

