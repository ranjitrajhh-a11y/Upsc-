    "Technology": {
      "AI": [],
      "Space Technology": [],
      "Biotech": [],
      "IT & Computers": []
    }
  },

  // =========================
  // 🌱 ENVIRONMENT
  // =========================
  "Environment": {

    "Ecology": {
      "Food Chain": [],
      "Food Web": [],
      "Ecosystem": []
    },

    "Biodiversity": {
      "Hotspots": [],
      "Species": [],
      "Conservation": []
    },

    "Climate Change": {
      "Global Warming": [],
      "Greenhouse Gases": [],
      "Paris Agreement": []
    }
  },

  // =========================
  // 🧠 ETHICS (GS4)
  // =========================
  "Ethics": {

    "Ethical Philosophy": [],
    "Integrity": [],
    "Attitude": [],
    "Emotional Intelligence": [],
    "Public Service Values": [],
    "Case Studies": []
  },

  // =========================
  // 🇮🇳 CURRENT AFFAIRS
  // =========================
  "Current Affairs": {

    "National": [],
    "International": [],
    "Economy": [],
    "Science & Tech": [],
    "Environment": [],
    "Government Schemes": [],
    "Defense": [],
    "Reports & Indexes": []
  }
};

let questions=[], selectedSubject=null;
let current=0,score=0,timeLeft=30,timer;
let userAnswers=[],wrongList=[];
let fullQuestions = [];
let page = 0;
let pageSize = 50;

function loadLevel2(){
  let cat = level1.value;
  if(!cat) return;

  let html = '<option value="">-- Section चुनें --</option>';

  Object.keys(data[cat]).forEach(sec=>{
    html += `<option value="${sec}">${sec}</option>`;
  });

  level2.innerHTML = html;
  level2.classList.remove("hidden");

  level3.classList.add("hidden");
  chapterSelect.classList.add("hidden");
}

function loadLevel3(){
  let cat = level1.value;
  let sec = level2.value;
  if(!cat || !sec) return;

  let html = '<option value="">-- Subject चुनें --</option>';

  Object.keys(data[cat][sec]).forEach(sub=>{
    html += `<option value="${sub}">${sub}</option>`;
  });

  level3.innerHTML = html;
  level3.classList.remove("hidden");

  chapterSelect.classList.add("hidden");
}

function loadChapters(){

  let cat = level1.value;
  let sec = level2.value;
  let sub = level3.value;

  if(!cat || !sec || !sub) return;

  selectedSubject = {cat, sec, sub};

  let html='<option value="">-- Chapter चुनें --</option>';

  Object.keys(data[cat][sec][sub]).forEach(ch=>{
    html+=`<option value="${ch}">${ch}</option>`;
  });

  chapterSelect.innerHTML=html;
  chapterSelect.classList.remove("hidden");
}

// 🔥 CHAPTER LOAD (FAST + OPTIMIZED)
function startFromDropdown(){

  let ch = chapterSelect.value;
  if(!ch) return;

  let {cat, sec, sub} = selectedSubject;

  // ✅ YE CHECK ADD KARO
  if(!data[cat][sec][sub][ch] || data[cat][sec][sub][ch].length === 0){
    alert("No questions available");
    return;
  }

  fullQuestions = shuffle(
  removeDuplicates(data[cat][sec][sub][ch])
);

  page = 0;
subjectBox.classList.add("hidden");
quizBox.classList.remove("hidden");
startQuiz();
}
function startQuiz(){
current=0;
score=0;
userAnswers=[];
wrongList=[];

loadPage(); // 🔥 सबसे जरूरी FIX
}

function loadPage(){
  let start = page * pageSize;
  let end = start + pageSize;

  questions = fullQuestions.slice(start, end);

  current = 0;
  loadQuestion();
}
function startTimer(){
clearInterval(timer);
timeLeft=30;
time.innerText=timeLeft;

timer=setInterval(()=>{
timeLeft--;
time.innerText=timeLeft;

if(timeLeft<=0){
clearInterval(timer);
let idx = page * pageSize + current;

if(userAnswers[idx] == null){
userAnswers[idx] = -1; // ✅ FIX: mark attempted
addWrong(questions[current]);
nextQuestion();
}
}
},1000);
}

function loadQuestion(){
if(!questions[current]) return showResult();

startTimer();
explanation.classList.add("hidden");

let q=questions[current];

// ✅ FIX: Auto numbering
question.innerText = `Q${page * pageSize + current + 1} / ${fullQuestions.length} : ${q.q}`;

let html="";
q.options.forEach((opt,i)=>{
let colors = ["opt1","opt2","opt3","opt4"];
let selected = userAnswers[page * pageSize + current] == i
  ? colors[i] + " ring-2 ring-yellow-300 scale-105" 
  : colors[i];

html+=`<div onclick="selectOption(${i})" class="${selected} p-3 rounded cursor-pointer">${opt}</div>`;
});

options.innerHTML=html;
let totalIndex = page * pageSize + current + 1;
progress.style.width = (totalIndex / fullQuestions.length) * 100 + "%";
}

function addWrong(q){
  if(!wrongList.some(x => x.q === q.q)){
    wrongList.push(q);
  }
}

function selectOption(i){
let idx = page * pageSize + current;
if(userAnswers[idx] != null) return;

clearInterval(timer);

let q=questions[current];
userAnswers[idx] = i;
saveState();
let opts=document.querySelectorAll("#options div");
opts.forEach(o=>o.style.pointerEvents="none");

if(i===q.answer){
opts[i].style.background = "green";
score++;
document.getElementById("score").innerText=score;
}else{
opts[i].style.background = "red";
opts[q.answer].style.background = "green";
addWrong(q);
}

explanation.innerText="Explanation: "+q.exp;
explanation.classList.remove("hidden");

setTimeout(nextQuestion,1500);
}

function nextQuestion(){
saveState();
current++;

if(current >= questions.length){
  page++;

  // 🔥 अगर सारे questions खत्म
  if(page * pageSize >= fullQuestions.length){
    return showResult();
  } else {
    loadPage(); // next batch load
    return;
  }
}

loadQuestion();
}

function goBack(){
clearInterval(timer);
saveState();
if(current > 0){
    current--;
    loadQuestion();
  } else if(page > 0){
    page--;
    loadPage();
    current = questions.length - 1;
    loadQuestion();
  }
}
function showResult(){
  clearInterval(timer);

  quizBox.classList.add("hidden");
  resultBox.classList.remove("hidden");

  let attemptedCount = userAnswers.filter(a => a != null).length;

  attempted.innerText = attemptedCount;
  correct.innerText = score;
  wrong.innerText = attemptedCount - score;
}

// ✅ FIX: fullQuestions update
function retakeWrong(){
  fullQuestions = shuffle(
    wrongList.filter((v,i,a)=>
      a.findIndex(t=>t.q === v.q) === i
    )
  );

  page = 0;
  current = 0;
  score = 0;
  userAnswers = [];
  wrongList = [];

  resultBox.classList.add("hidden");
  quizBox.classList.remove("hidden");

  loadPage();
}

// 🔥 PERFECT RESTART
function restartQuiz(){
localStorage.removeItem("quizState");
clearInterval(timer);

current=0;
score=0;
userAnswers=[];
wrongList=[];
questions=[];
selectedSubject=null;

document.getElementById("score").innerText=0;
time.innerText=30;
progress.style.width="0%";
explanation.classList.add("hidden");

resultBox.classList.add("hidden");
quizBox.classList.add("hidden");
subjectBox.classList.remove("hidden");

level1.value="";
level2.value="";
level3.value="";
chapterSelect.value="";

level2.classList.add("hidden");
level3.classList.add("hidden");
chapterSelect.classList.add("hidden");
}

function openExitPopup(){
  const popup = document.getElementById("exitPopup");
  
  // अगर पहले से खुला है तो कुछ मत करो
  if(!popup.classList.contains("hidden")) return;

  popup.classList.remove("hidden");
}

function closeExitPopup(){
  document.getElementById("exitPopup").classList.add("hidden");
}

function confirmExit(){
  clearInterval(timer);
localStorage.removeItem("quizState");
  document.getElementById("exitPopup").classList.add("hidden");
  quizBox.classList.add("hidden");
  subjectBox.classList.remove("hidden");
}
window.onload = function(){
  loadState();
};
</script>
<div id="exitPopup" onclick="closeExitPopup()" class="fixed inset-0 bg-black bg-opacity-70 hidden flex items-center justify-center">
  
  <div class="bg-gray-800 p-6 rounded-xl text-center w-80" onclick="event.stopPropagation()">
    
    <h2 class="text-lg mb-4">क्या आप quiz छोड़ना चाहते हैं?</h2>

    <div class="flex justify-around">
      <button onclick="confirmExit()" class="bg-red-500 px-4 py-2 rounded">Yes</button>
      <button onclick="closeExitPopup()" class="bg-green-500 px-4 py-2 rounded">No</button>
    </div>

  </div>
</div>
</body>
